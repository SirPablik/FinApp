@page "{id:int}"
@model FinPlan.Web.Pages.Investments.DeleteModel
@{
    ViewData["Title"] = "Удалить актив";
}

<h1>@ViewData["Title"]</h1>

<h3>Вы уверены, что хотите удалить этот актив?</h3>

<div class="card">
    <div class="card-body">
        <p><strong>Актив:</strong> @Model.Investment.AssetName</p>
        <p><strong>Тип:</strong> @Model.Investment.AssetType</p>
        <p><strong>Количество:</strong> @Model.Investment.Quantity</p>
        <p><strong>Цена:</strong> @Model.Investment.PurchasePrice.ToString("N2") ₽</p>
        <p><strong>Стоимость:</strong> @((Model.Investment.Quantity * Model.Investment.PurchasePrice).ToString("N2")) ₽</p>
        <p><strong>Дата:</strong> @Model.Investment.PurchaseDate.ToString("dd.MM.yyyy")</p>
    </div>
</div>

<form method="post" class="mt-4">
    <input type="hidden" asp-for="Investment.Id" />
    <button type="submit" class="btn btn-danger">🗑️ Удалить</button>
    <a asp-page="Index" class="btn btn-secondary">↩️ Отмена</a>
</form>