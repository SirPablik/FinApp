@page
@model FinPlan.Web.Pages.Budgets.IndexModel
@{
    ViewData["Title"] = "Бюджеты";
    ViewData["page"] = "Budgets";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">➕ Создать бюджет</a>
    <a asp-page="Index" asp-page-handler="Export" class="btn btn-success">📊 Экспорт в CSV</a>
</p>

<!-- Форма фильтров -->
<div class="card mb-4">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">🔍 Фильтры</h5>
    </div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <!-- Категория -->
            <div class="col-md-4">
                <label class="form-label">Категория</label>
                <select name="CategoryFilter" class="form-select">
                    <option value="">Все</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat" selected="@(cat == Model.CategoryFilter)">@cat</option>
                    }
                </select>
            </div>

            <!-- Статус -->
            <div class="col-md-4">
                <label class="form-label">Статус</label>
                <select name="StatusFilter" class="form-select">
                    <option value="">Все</option>
                    <option value="Active" selected="@(Model.StatusFilter == "Active")">Активные</option>
                    <option value="Completed" selected="@(Model.StatusFilter == "Completed")">Завершённые</option>
                </select>
            </div>

            <!-- Кнопки -->
            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary">🔍 Применить</button>
            </div>
        </form>

        <!-- Кнопка сброса -->
        @if (!string.IsNullOrEmpty(Model.CategoryFilter) || !string.IsNullOrEmpty(Model.StatusFilter))
        {
            <div class="mt-3">
                <a asp-page="Index" class="btn btn-outline-secondary btn-sm">🔄 Сбросить фильтры</a>
            </div>
        }
    </div>
</div>

<!-- Таблица бюджетов -->
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Категория</th>
            <th>Лимит</th>
            <th>Потрачено</th>
            <th>Остаток</th>
            <th>Период</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Budgets)
        {
            var percent = item.Budget.Limit > 0 ? (item.Spent / item.Budget.Limit) * 100 : 0;
            var isOverBudget = item.Remaining < 0;
            var isNearLimit = !isOverBudget && percent >= 80;

            <tr class="@(isOverBudget ? "table-danger" : isNearLimit ? "table-warning" : "")">
                <td>@item.Budget.Category</td>
                <td>@item.Budget.Limit.ToString("N2") ₽</td>
                <td>@item.Spent.ToString("N2") ₽</td>
                <td class="@(item.Remaining >= 0 ? "text-success" : "text-danger fw-bold")">
                    @item.Remaining.ToString("N2") ₽
                </td>
                <td>
                    <div class="progress" style="height: 20px;">
                        <div class="progress-bar @(isOverBudget ? "bg-danger" : isNearLimit ? "bg-warning" : "bg-success")"
                             role="progressbar"
                             style="width: @Math.Min(percent, 100)%"
                             aria-valuenow="@percent"
                             aria-valuemin="0"
                             aria-valuemax="100">
                            @percent.ToString("N0")%
                        </div>
                    </div>
                </td>
                <td>
                    @if (isOverBudget)
                    {
                        <span class="badge bg-danger">⚠️ Превышен</span>
                    }
                    else if (isNearLimit)
                    {
                        <span class="badge bg-warning text-dark">⚠️ Почти готов</span>
                    }
                    else if (item.Budget.EndDate >= DateTime.Now)
                    {
                        <span class="badge bg-success">Активен</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Завершён</span>
                    }
                </td>
                <td>
                    <a asp-page="Edit" asp-route-id="@item.Budget.Id" class="btn btn-sm btn-warning">✏️</a>
                    <a asp-page="Delete" asp-route-id="@item.Budget.Id" class="btn btn-sm btn-danger">🗑️</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Budgets.Any())
{
    <div class="alert alert-info">
        <p>Нет бюджетов по выбранным фильтрам.</p>
    </div>
}